{
  "name": "@chainsafe/canton-snap-workspace",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "MetaMask Snap for non-custodial Canton Network signing",
  "license": "MIT",
  "workspaces": [
    "packages/snap",
    "packages/dapp"
  ],
  "scripts": {
    "build": "npm run build:snap && npm run build:dapp",
    "build:snap": "npm -w packages/snap run build",
    "build:dapp": "npm -w packages/dapp run build",
    "watch:snap": "npm -w packages/snap run watch",
    "serve:snap": "npm -w packages/snap run serve",
    "dev:dapp": "npm -w packages/dapp run dev",
    "serve": "concurrently -n snap,dapp -c cyan,magenta \"npm run serve:snap\" \"npm run dev:dapp\"",
    "test": "npm run test:snap:unit",
    "test:snap:unit": "npm -w packages/snap run test:crypto",
    "lint": "eslint packages/snap/src packages/dapp/src",
    "lint:fix": "eslint packages/snap/src packages/dapp/src --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
