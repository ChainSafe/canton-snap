# Canton Snap port (used to construct the MetaMask Snap ID)
VITE_SNAP_PORT=8080

# Default network shown on first load (mainnet | devnet | local)
VITE_DEFAULT_NETWORK=local

# Per-network middleware base URLs
VITE_LOCAL_MIDDLEWARE_URL=http://localhost:8081

# Per-network host labels shown in the network switcher (optional overrides)
# VITE_LOCAL_HOST=localhost:8081
